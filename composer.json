{
  "name": "plumthedev/json-shape",
  "description": "TBA",
  "type": "library",
  "keywords": [
    "json",
    "shape",
    "schema",
    "php"
  ],
  "homepage": "https://github.com/plumthedev/json-shape",
  "license": "MIT",
  "authors": [
    {
      "name": "Kacper Pruszyński (plumthedev)",
      "email": "kacper.pruszysnki99@gmail.com",
      "homepage": "https://github.com/plumthedev"
    }
  ],
  "support": {
    "issues": "https://github.com/plumthedev/json-shape/issues",
    "source": "https://github.com/plumthedev/json-shape"
  },
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Plumthedev\\JsonShape\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Plumthedev\\JsonShape\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "audit": {
      "abandoned": "report"
    },
    "allow-plugins": {}
  }
}